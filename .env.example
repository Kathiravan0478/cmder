# Code Logger – copy to .env and fill in for your environment.
# Portable: works on Windows, macOS, and Linux.

# ----- Backend (optional: use Docker Compose and set in docker-compose) -----
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Qdrant (default: localhost when running without Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# Embeddings: Gemini (recommended in paper)
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI_EMBEDDING=true
EMBEDDING_MODEL=models/embedding-001

# LLM for summarization / answer-query: Groq (fast) or Gemini
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_LLM_MODEL=gemini-1.5-flash

# ----- CLI / Extension (optional) -----
# Override API URL when backend runs elsewhere (e.g. Docker host)
# CODE_LOGGER_API_URL=http://localhost:5000
