# Code Logger – copy to .env and fill in for your environment.
# Portable: works on Windows, macOS, and Linux.

# ----- Backend (optional: use Docker Compose and set in docker-compose) -----
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Port for local run (default 5001 to avoid macOS AirPlay on 5000). Set PORT or FLASK_PORT.
# FLASK_PORT=5001

# Qdrant (default: localhost when running without Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# Embeddings: Gemini (recommended in paper)
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI_EMBEDDING=true
EMBEDDING_MODEL=models/embedding-001

# LLM for summarization / answer-query: Groq (fast) or Gemini
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_LLM_MODEL=gemini-1.5-flash

# ----- CLI / Extension (when backend runs in Docker) -----
# On the host, CLI and VSCode extension use this to reach the backend.
# Default http://localhost:5000 works when using docker-compose (ports 5000:5000).
# CODE_LOGGER_API_URL=http://localhost:5000
